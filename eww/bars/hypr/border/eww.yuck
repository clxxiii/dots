(defwindow monitor-border
  :monitor 0
  :geometry (geometry :x "0px"
                      :y "0px"
                      :width "100%"
                      :height "100%"
                      :anchor "top left")
  :stacking "bottom"
  :windowtype "dock"
  :focusable false
  :hexpand false
  (box 
    :class "border"
    (box 
      :class "shadow"
      (empty)
      )
    )
)

